NODE_ENV=development
PORT=3001
API_PORT=3001
BASE_PATH=/
WEB_DIST_DIR=./artifacts/inventory/dist/public
ALLOW_CROSS_ENV_DB=false

DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
SESSION_SECRET=change-me-to-a-long-random-string

# ── Upload storage (REQUIRED on every environment) ────────────────────
# Absolute path to the upload directory.
# This path MUST be outside the application directory so that deploys never
# delete uploaded files.
#
# Linux production:  LOCAL_UPLOAD_DIR=/srv/royal-note/shared/uploads
# Linux staging:     LOCAL_UPLOAD_DIR=/srv/royal-note-staging/shared/uploads
# macOS dev:         LOCAL_UPLOAD_DIR=/Users/yourname/.local/share/royal-note-dev/uploads
# Windows dev:       LOCAL_UPLOAD_DIR=D:\royal-note-data\uploads
#
# The server will REFUSE to start if this value is missing or points inside
# the application directory.
LOCAL_UPLOAD_DIR=

# ── Replit GCS (optional — Replit deployments only) ──────────────────────────
# Set REPLIT_ENV=true ONLY when running on Replit infrastructure.
# Leave unset or false on any Linux VPS / local machine.
REPLIT_ENV=false
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=
